======================================
Created View for customers info
=======================================

create view Gold.Dim_customers as  
select 
row_number() over(order by customer_id) as customer_key, 
customer_id,
customer_number,
firstname,
lastname,
country,
marital_status,
Gender,
birthdate,
creation_date
from
(select cst_id as customer_id,
cst_key as customer_number,
cst_firstname as firstname,
cst_lastname as lastname,
cntry as country,
cst_marital_status as marital_status,
case
   when cst_gndr!='n\a' then cst_gndr
   else coalesce(gen,'n\a') 
end as Gender,
BDATE as birthdate,
cst_create_date as creation_date

from(select *,
row_number() over(partition by cst_key order by cst_id) as flagcount
from 
(select ci.cst_id,
ci.cst_key,
ci.cst_firstname,
ci.cst_lastname,
ci.cst_marital_status,
ci.cst_gndr,
ci.cst_create_date,
ca.cid,
ca.bdate,
ca.gen,
la.cntry
from silver.crm_cust_info ci
left join silver.erp_CUST_AZ12 ca
on ci.cst_key= ca.cid
left join silver.erp_LOC_A101 la
on ci.cst_key=la.cid) t)p
where flagcount=1) y

