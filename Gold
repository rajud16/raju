======================================
Created View for customers info
=======================================

create view Gold.Dim_customers as  
select 
row_number() over(order by customer_id) as customer_key, 
customer_id,
customer_number,
firstname,
lastname,
country,
marital_status,
Gender,
birthdate,
creation_date
from
(select cst_id as customer_id,
cst_key as customer_number,
cst_firstname as firstname,
cst_lastname as lastname,
cntry as country,
cst_marital_status as marital_status,
case
   when cst_gndr!='n\a' then cst_gndr
   else coalesce(gen,'n\a') 
end as Gender,
BDATE as birthdate,
cst_create_date as creation_date

from(select *,
row_number() over(partition by cst_key order by cst_id) as flagcount
from 
(select ci.cst_id,
ci.cst_key,
ci.cst_firstname,
ci.cst_lastname,
ci.cst_marital_status,
ci.cst_gndr,
ci.cst_create_date,
ca.cid,
ca.bdate,
ca.gen,
la.cntry
from silver.crm_cust_info ci
left join silver.erp_CUST_AZ12 ca
on ci.cst_key= ca.cid
left join silver.erp_LOC_A101 la
on ci.cst_key=la.cid) t)p
where flagcount=1) y

======================================
Created View for product info
=======================================

create view gold.dim_product as 
select 

row_number() over (order by ci.prd_start_dt,ci.prd_key) as product_key,
ci.prd_id as product_id,
ci.prd_key as product_number,
ci.prd_nm as product_name,
ci.cat_id as category_id,
cp.cat as category,
cp.subcat as subcategory,
cp.maintenance,
ci.prd_cost as cost,
ci.prd_line as product_line,
ci.prd_start_dt as startdate
from silver.crm_prd_info ci
left join silver.erp_PX_CAT_G1V2 cp
on ci.cat_id=cp.id

where prd_end_dt is null

