================================================
Magnitude Analysis
====================================================



--find the total customers by country

select * from gold.dim_customers
select * from gold.dim_product
select * from gold.fact_sales
select country,
count(distinct customer_id) as totalcustomers
from gold.dim_customers
group by country
order by totalcustomers desc

--find the total customers by gender
select gender,
count(distinct customer_id) as totalgendercustomers 
from gold.dim_customers
group by gender
order by totalgendercustomers  desc

--find the total products by category
select category,
count(distinct product_id) as totalproducts 
from gold.dim_product
group by category 
order by totalproducts desc
--what is the avg cost in each category

select category,
avg(cost) as avgcost 
from gold.dim_product
group by category 
order by avgcost desc

--what is total revenue generated by each category

select category, 
sum(sales_amount) as totalrevenue 
from(select p.category,
f.sales_amount from gold.fact_sales f
left join gold.dim_product p
on p.product_key = f.product_key) t
group by category


----(or)

select p.category,sum(f.sales_amount) totalrevenue
from gold.fact_sales f
left join gold.dim_product p
on f.product_key= p.product_key
group by category
order by totalrevenue desc



select category, sum(sales_amount) as totalrevenue from(select p.category,
f.sales_amount from gold.dim_product p
inner join gold.fact_sales f
on p.product_key = f.product_key) t
group by category


---what is the distribution of sold items across country

select country,sum(quantity) as solditems from (select c.country,f.quantity from 
gold.dim_customers c 
left join 
gold.fact_sales f on c.customer_key = f.customer_key) t
group by country

----(or)

select c.country,sum(f.quantity) as totalsolditmes
from gold.fact_sales f
left join gold.dim_customers c
on f.customer_key=c.customer_key
group by country
order by totalsolditmes desc

----what is the total revenue generated by each customer
select c.firstname,c.lastname,c.customer_key,sum(f.sales_amount) as totalrevenue
from gold.fact_sales f
left join gold.dim_customers c
on f.customer_key= c.customer_key
group by c.firstname,c.lastname,c.customer_key
order by totalrevenue desc

====================================
----Ranking Analysis
=========================================

---rank(dimensions) by (measure)
----countries by total sales
--which five 5 products generate the highest revenue

select * from gold.dim_product
select * from gold.fact_sales

select top 5 p.product_name,sum(f.sales_amount) totalrevenue
from gold.fact_sales f
left join gold.dim_product p
on f.product_key= p.product_key
group by p.product_name
order by totalrevenue desc

select top 5 p.product_name,sum(f.sales_amount) totalrevenue
from gold.fact_sales f
left join gold.dim_product p
on f.product_key= p.product_key
group by p.product_name
order by totalrevenue 

----using window functions

select * from (select product_name,sum(f.sales_amount) as totalrevenue,

row_number() over ( order by sum(f.sales_amount) desc) as rownumber
from gold.fact_sales f
left join gold.dim_product p
on f.product_key= p.product_key
group by p.product_name) t 
where rownumber <=5

----find the top10 customers who have generated the highest revenue 


select * from (select  c.firstname,c.lastname,c.customer_key,sum(f.sales_amount) as totalrevenue,
row_number() over (order by sum(f.sales_amount) desc) as ranking
from gold.fact_sales f
left join gold.dim_customers c
on f.customer_key= c.customer_key
group by c.firstname,c.lastname,c.customer_key) t
where ranking<=10 

------3 customers with the fewesr orders place

select top 3 c.customer_key,c.firstname,c.lastname,
count(distinct order_number)as lowestorders 
from gold.fact_sales f
left join gold.dim_customers c
on c.customer_key= f.customer_key
group by c.customer_key,c.firstname,c.lastname
order by lowestorders

