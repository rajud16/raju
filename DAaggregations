EDA(Exploratory data analysis)
==========================================


----find the first order and lsat order
-----how many years/days/month of sales available

select * from gold.fact_sales


select
max(order_date) as lastorder,
min(order_date) as firstorder,
datediff(year,min(order_date),max(order_date)) as numberofyearsales,
datediff(month,min(order_date),max(order_date)) as numberofmonthsales,
datediff(day,min(order_date),max(order_date)) as numberofdaysales
from gold.fact_sales


---find the youngest and oldest customers

select * from gold.dim_customers
select min(birthdate) as oldest,
max(birthdate) as youngest,
datediff(year,min(birthdate),getdate()) as oldage,
datediff(year,max(birthdate),getdate()) as youngest from gold.dim_customers


select * from gold.fact_sales
select * from gold.dim_product
select * from gold.dim_customers

--find the total sales

select sum(sales_amount) as totalsale from gold.fact_sales

---how may items are sold

select sum(quantity) as totalquantity from gold.fact_sales

-------find the avg selling price
select avg(price) as avgprice from gold.fact_sales

---find the total number of orders
select count(distinct order_number) as totalordnumber from gold.fact_sales
----find the total number of products

select count(product_key) totalnumberproducts from gold.dim_product
---find the total number of customers

select count(customer_id) as totalcustomers from gold.dim_customers

--find the total number of customers that has placed an order

select count(distinct customer_key) as totalcustomers from gold.fact_sales
